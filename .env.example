# Copiază în .env (nu comita .env).

# Google OAuth — Redirect: http://127.0.0.1:8000/accounts/google/login/callback/
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# PostgreSQL — dacă POSTGRES_DB e setat, Django folosește Postgres (driver: psycopg3).
# Lasă POSTGRES_DB gol pentru SQLite local (db.sqlite3).
# POSTGRES_DB=foculmatematic
# POSTGRES_USER=foculuser
# POSTGRES_PASSWORD=schimba_ma
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# Opțional: durată (secunde) păstrare conexiuni în pool; 0 = la fiecare request
# POSTGRES_CONN_MAX_AGE=60
